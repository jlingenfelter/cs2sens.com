---
interface Props {
  defaultFrom?: string;
  defaultTo?: string;
}
const { defaultFrom = 'cs2', defaultTo = 'valorant' } = Astro.props;
const id = `conv-${Math.random().toString(36).slice(2,8)}`;
---
<div class="card" id={id}>
  <h2>Convert Sensitivity</h2>
  <div class="form-row">
    <div class="form-group">
      <label for={`${id}-from`}>Game From</label>
      <select id={`${id}-from`}>
        <option value="cs2" selected={defaultFrom === 'cs2'}>CS2</option>
        <option value="valorant" selected={defaultFrom === 'valorant'}>Valorant</option>
        <option value="apex" selected={defaultFrom === 'apex'}>Apex Legends</option>
        <option value="overwatch2" selected={defaultFrom === 'overwatch2'}>Overwatch 2</option>
        <option value="r6" selected={defaultFrom === 'r6'}>Rainbow Six Siege</option>
        <option value="fortnite" selected={defaultFrom === 'fortnite'}>Fortnite</option>
      </select>
    </div>
    <div class="form-group">
      <label for={`${id}-to`}>Game To</label>
      <select id={`${id}-to`}>
        <option value="cs2" selected={defaultTo === 'cs2'}>CS2</option>
        <option value="valorant" selected={defaultTo === 'valorant'}>Valorant</option>
        <option value="apex" selected={defaultTo === 'apex'}>Apex Legends</option>
        <option value="overwatch2" selected={defaultTo === 'overwatch2'}>Overwatch 2</option>
        <option value="r6" selected={defaultTo === 'r6'}>Rainbow Six Siege</option>
        <option value="fortnite" selected={defaultTo === 'fortnite'}>Fortnite</option>
      </select>
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for={`${id}-sens`}>Sensitivity</label>
      <input type="number" id={`${id}-sens`} placeholder="e.g. 2.0" step="any" min="0">
    </div>
    <div class="form-group">
      <label for={`${id}-dpi`}>DPI</label>
      <input type="number" id={`${id}-dpi`} placeholder="e.g. 800" step="any" min="0">
    </div>
  </div>
  <button class="btn" id={`${id}-btn`}>Convert</button>
  <div class="result-box" id={`${id}-result`}>
    <div class="label" id={`${id}-rlabel`}>Converted Sensitivity</div>
    <div class="val" id={`${id}-rval`}>0.000</div>
    <div class="sub" id={`${id}-rsub`}></div>
  </div>
</div>

<script define:vars={{ id }}>
(function(){
  const M={cs2:1,valorant:0.314,apex:1,overwatch2:10.6,r6:12.2,fortnite:0.708};
  const el=s=>document.getElementById(id+s);
  el('-btn').addEventListener('click',function(){
    const f=el('-from').value,t=el('-to').value;
    const s=parseFloat(el('-sens').value),d=parseFloat(el('-dpi').value);
    if(isNaN(s)||s<=0)return;
    const c=s*(M[t]/M[f]);
    const r=el('-result');r.classList.add('visible');
    el('-rval').textContent=c.toFixed(3);
    let sub='';
    if(!isNaN(d)&&d>0){
      const edpi=c*d;
      const cm=(2.54*360)/(c*d*0.022);
      sub='eDPI: '+edpi.toFixed(0)+' · cm/360: '+cm.toFixed(1)+' cm';
    }
    el('-rsub').textContent=sub;
  });
})();
</script>
